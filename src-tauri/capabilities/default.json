{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-set-overlay-icon",
    "deep-link:default",
    "notification:default",
    "updater:default",
    "process:allow-restart",
    "shell:allow-open"
  ]
}
